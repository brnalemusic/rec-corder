{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rec Corder",
  "version": "0.1.2",
  "identifier": "com.reccorder.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Rec Corder",
        "visible": false,
        "width": 380,
        "height": 730,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "center": true
      },
      {
        "label": "splash",
        "url": "splash.html",
        "title": "Testando Ambiente",
        "width": 300,
        "height": 400,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; font-src 'self' data:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' tauri: ipc:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
