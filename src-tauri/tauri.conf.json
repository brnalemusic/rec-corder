{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rec Corder",
  "version": "1.0.0-beta.1",
  "identifier": "com.reccorder.app",
  "build": {
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "npm run sync"
    },
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "splash",
        "url": "splash.html",
        "title": "Testando Ambiente",
        "width": 300,
        "height": 400,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; font-src 'self' https://cdn.jsdelivr.net data:; img-src 'self' data: blob:; style-src 'self' https://cdn.jsdelivr.net 'unsafe-inline'; script-src 'self' https://cdn.jsdelivr.net; connect-src 'self' tauri: ipc:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "deb",
      "appimage"
    ],
    "externalBin": [
      "bin/ffmpeg"
    ],
    "resources": [
      "../UPDATE.md"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/header.bmp",
        "sidebarImage": "installer-assets/sidebar.bmp",
        "installerHooks": "nsis_hook.nsh"
      },
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFQzE4ODk5OTE1MjI4QTAKUldTZ0tGS1JtWWpCWGlkQTVoTWgxQVgyLy93MXlpeW85UFZSejQ0aTNleUxOYXpqSW4rdVZ0UVAK",
      "endpoints": [
        "https://github.com/brnalemusic/rec-corder/releases/latest/download/latest.json"
      ]
    }
  }
}
