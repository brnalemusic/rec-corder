{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rec Corder",
  "version": "0.2.1",
  "identifier": "com.reccorder.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Rec Corder",
        "visible": false,
        "width": 380,
        "height": 730,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "center": true
      },
      {
        "label": "splash",
        "url": "splash.html",
        "title": "Testando Ambiente",
        "width": 300,
        "height": 400,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": true
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "Configurações - Rec Corder",
        "width": 500,
        "height": 650,
        "resizable": true,
        "minWidth": 450,
        "minHeight": 550,
        "decorations": true,
        "transparent": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; font-src 'self' data:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' tauri: ipc:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFQzE4ODk5OTE1MjI4QTAKUldTZ0tGS1JtWWpCWGlkQTVoTWgxQVgyLy93MXlpeW85UFZSejQ0aTNleUxOYXpqSW4rdVZ0UVAK",
      "endpoints": [
        "https://github.com/brnalemusic/rec-corder/releases/latest/download/latest.json"
      ]
    }
  }
}